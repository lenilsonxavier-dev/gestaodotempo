<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Gestão do Tempo 2026 | Professor Leno</title>
    <style>
        * { box-sizing: border-box; }
        :root {
            --cor-htp: #add8e6;
            --cor-mes-atual: #90ee90;
            --cor-feriado: #ff4500;
            --cor-conselho: #b39ddb;
            --cor-recesso: #ffb300;
        }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #eef2f5;
            margin: 0;
            padding: 10px;
            display: flex;
            justify-content: center;
        }
        .calendario-wrapper {
            max-width: 1200px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .header-institucional {
            background: linear-gradient(135deg, #0a2f6c 0%, #1b4a8b 100%);
            color: white;
            padding: 20px;
            text-align: center;
            border-bottom: 4px solid #ffb300;
        }
        .nome-cidade { font-size: 1.8rem; font-weight: 800; margin: 5px 0; }
        .gestao-tempo h2 {
            font-size: 1.5rem;
            margin: 5px 0;
            background: linear-gradient(120deg, #ffb300, #ffdd77);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .unidade-editavel input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 20px;
            padding: 5px 15px;
            color: white;
            width: 80%;
            text-align: center;
        }
        .nav-mes {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #2c3e50;
            padding: 10px 20px;
            color: white;
        }
        .nav-btn {
            background: #f1c40f;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: bold;
        }
        .grade-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        .grade-table th, .grade-table td {
            border: 1px solid #dee2e6;
            vertical-align: top;
            height: 90px;
        }
        .grade-table th { background: #f8f9fa; font-size: 0.7rem; height: 30px; }
        .cell-day { position: relative; height: 100%; display: flex; flex-direction: column; }
        .day-number { font-weight: bold; padding: 2px 6px; font-size: 0.9rem; }
        .agenda-text { font-size: 10px; padding: 2px 5px; height: 60px; overflow-y: auto; outline: none; }
        .notif-badge { position: absolute; top: 2px; right: 2px; font-size: 10px; }
        
        .htp-bg { background-color: var(--cor-htp) !important; }
        .feriado-bg { background-color: var(--cor-feriado) !important; color: white; }
        .conselho-bg { background-color: var(--cor-conselho) !important; }
        .recesso-bg { background-color: var(--cor-recesso) !important; }
        .domingo-bg { background-color: #ffebee; }
        .sabado-bg { background-color: #e3f2fd; }

        .legenda-painel { padding: 10px; background: #f8f9fa; font-size: 10px; text-align: center; border-top: 1px solid #ddd; }
        .btn-acao { background: #2c3e50; color: white; border: none; padding: 5px 12px; border-radius: 15px; cursor: pointer; margin: 2px; }
    </style>
</head>
<body>

<div class="calendario-wrapper">
    <div class="header-institucional">
        <div class="prefeitura">PREFEITURA DE</div>
        <div class="nome-cidade">OSASCO</div>
        <div class="gestao-tempo"><h2>Gestão do Tempo</h2></div>
        <div class="unidade-editavel">
            <input type="text" id="unidadeNome" value="E.M. QUINTINO BOCAIUVA">
        </div>
    </div>

    <div class="nav-mes">
        <button class="nav-btn" onclick="mudarMes(-1)">◀</button>
        <div id="mesTitle" style="font-weight: bold; font-size: 1.2rem;"></div>
        <button class="nav-btn" onclick="mudarMes(1)">▶</button>
    </div>

    <table class="grade-table">
        <thead><tr id="weekRow"></tr></thead>
        <tbody id="calendarBody"></tbody>
    </table>

    <div class="legenda-painel">
        <span>🔵 HTP | 🔴 Feriado | 🟣 Conselho | 🟡 Recesso</span><br>
        <button class="btn-acao" onclick="window.print()">🖨️ Imprimir</button>
        <button class="btn-acao" onclick="testarAudio()">🔊 Som</button>
    </div>
</div>

<script>
    // --- CONFIGURAÇÃO ---
    const FIREBASE_URL = "SUA_URL_DO_FIREBASE_AQUI/agenda.json"; 

    let anoAtual = 2026;
    let mesAtual = 3; 
    let agendaData = {};

    const mesesNomes = ["JANEIRO","FEVEREIRO","MARÇO","ABRIL","MAIO","JUNHO","JULHO","AGOSTO","SETEMBRO","OUTUBRO","NOVEMBRO","DEZEMBRO"];
    const weekDays = ["DOM", "SEG", "TER", "QUA", "QUI", "SEX", "SAB"];
    const feriados = {"3-21": "feriado", "4-1": "feriado", "3-27": "conselho", "3-28": "conselho"};

    // Função de carregar blindada
    async function carregarDados() {
        try {
            const res = await fetch(FIREBASE_URL);
            if (!res.ok) throw new Error("Erro Firebase");
            const data = await res.json();
            if(data) agendaData = data;
        } catch(e) {
            console.warn("Firebase não respondeu, usando cache local.");
            // Tenta pegar do LocalStorage se o Firebase falhar
            agendaData = JSON.parse(localStorage.getItem('agenda_backup')) || {};
        }
        render();
    }

    async function salvarNoFirebase(dia, texto) {
        const key = `${anoAtual}-${mesAtual}-${dia}`;
        agendaData[key] = texto;
        
        // Salva no backup local primeiro por segurança
        localStorage.setItem('agenda_backup', JSON.stringify(agendaData));

        try {
            await fetch(FIREBASE_URL, {
                method: 'PUT',
                body: JSON.stringify(agendaData)
            });
        } catch(e) { console.error("Erro ao sincronizar com Firebase"); }

        if(texto.toUpperCase().includes("HTPC")) testarAudio();
        render(); 
    }

    function mudarMes(delta) {
        mesAtual += delta;
        if(mesAtual > 11) { mesAtual = 0; anoAtual++; }
        if(mesAtual < 0) { mesAtual = 11; anoAtual--; }
        render();
    }

    function testarAudio() {
        try {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain); gain.connect(ctx.destination);
            osc.start(); gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.5);
            setTimeout(() => osc.stop(), 500);
        } catch(e) {}
    }

    function render() {
        const tbody = document.getElementById("calendarBody");
        const title = document.getElementById("mesTitle");
        if(!tbody || !title) return;

        tbody.innerHTML = "";
        title.innerText = `${mesesNomes[mesAtual]} ${anoAtual}`;

        const primeiroDia = new Date(anoAtual, mesAtual, 1).getDay();
        const diasNoMes = new Date(anoAtual, mesAtual + 1, 0).getDate();

        let diaCont = 1;
        for (let i = 0; i < 6; i++) {
            let row = document.createElement("tr");
            for (let j = 0; j < 7; j++) {
                let cell = document.createElement("td");
                if ((i === 0 && j < primeiroDia) || diaCont > diasNoMes) {
                    cell.style.background = "#f1f3f5";
                } else {
                    const d = diaCont;
                    const key = `${anoAtual}-${mesAtual}-${d}`;
                    const texto = agendaData[key] || "";
                    
                    if(j === 0) cell.className = "domingo-bg";
                    else if(j === 6) cell.className = "sabado-bg";
                    else if(j === 2 || j === 4) cell.className = "htp-bg";
                    
                    if(feriados[`${mesAtual}-${d}`]) cell.classList.add(feriados[`${mesAtual}-${d}`] + "-bg");

                    cell.innerHTML = `
                        <div class="cell-day">
                            <div class="day-number">${d}</div>
                            <div class="agenda-text" contenteditable="true" onblur="salvarNoFirebase(${d}, this.innerText)">${texto}</div>
                            ${texto.toUpperCase().includes("HTPC") ? '<div class="notif-badge">🔔</div>' : ''}
                        </div>
                    `;
                    diaCont++;
                }
                row.appendChild(cell);
            }
            tbody.appendChild(row);
            if (diaCont > diasNoMes) break;
        }
    }

    // Inicializar
    const headerRow = document.getElementById("weekRow");
    headerRow.innerHTML = "";
    weekDays.forEach(d => headerRow.innerHTML += `<th>${d}</th>`);
    carregarDados();
</script>
</body>
</html>
